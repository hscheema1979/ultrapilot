{
  "name": "ultrapilot",
  "version": "1.0.0",
  "description": "Universal Development Workflow - The one plugin you need. Includes Relay Web UI, 29 specialist agents, and Google Chat integration.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "test": "vitest",
    "lint": "eslint src/",
    "prepare": "npm run build",
    "relay": "node relay/bin/cli.js",
    "relay:dev": "node relay/bin/cli.js --dev",
    "gateway": "node dist/server.js",
    "start": "npm run relay",
    "discover-agents": "node dist/cli/commands/discover-agents.js",
    "dashboard": "node dist/cli/commands/dashboard.js"
  },
  "keywords": [
    "claude-code",
    "agent-orchestration",
    "multi-agent",
    "autonomous-development",
    "ultrapilot",
    "web-ui",
    "relay",
    "google-chat"
  ],
  "author": "Ultrapilot Contributors",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.6.0",
    "chokidar": "^4.0.1",
    "express": "^4.18.2",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "octokit": "^5.0.5",
    "typescript": "^5.0.0",
    "uuid": "^9.0.0",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.10",
    "eslint": "^8.0.0",
    "supertest": "^7.2.2",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ultrapilot/ultrapilot-plugin"
  },
  "bugs": {
    "url": "https://github.com/ultrapilot/ultrapilot-plugin/issues"
  },
  "homepage": "https://github.com/ultrapilot/ultrapilot-plugin#readme"
}
